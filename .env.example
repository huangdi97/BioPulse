# ============================================================
# 一云四端 · 环境变量模板
# 复制本文件为 .env 后按需修改
# ============================================================

# ---------- 认证 ----------
SECRET_KEY=your-production-key-here                         # JWT 签名密钥（生产环境务必使用强随机串）
ALGORITHM=HS256                                          # JWT 加密算法
ACCESS_TOKEN_EXPIRE_MINUTES=30                           # Access Token 过期时间（分钟）
REFRESH_TOKEN_EXPIRE_DAYS=7                              # Refresh Token 过期时间（天）

# ---------- AI 网关 ----------
AI_GATEWAY_URL=http://localhost:8000/ai/chat             # AI 网关地址
AI_GATEWAY_TIMEOUT=120                                   # AI 网关超时时间（秒）
DEEPSEEK_API_KEY=                                        # DeepSeek API 密钥
DIGITAL_HUMAN_PROVIDER=                                  # 数字人服务提供商

# ---------- 数据库（各端独立） ----------
DATABASE_URL=sqlite:///./data/cloud.db                   # 云服务数据库
ASSISTANT_DATABASE_URL=sqlite:///./data/assistant.db     # 助手端数据库
OPPORTUNITY_DATABASE_URL=sqlite:///./data/opportunity.db # 机会端数据库
SALES_ASSISTANT_DATABASE_URL=sqlite:///./data/sales_assistant.db  # 销售助手端数据库
SALES_COACH_DATABASE_URL=sqlite:///./data/sales_coach.db         # 销售教练端数据库
DB_POOL_SIZE=5                                           # 数据库连接池大小
DB_MAX_OVERFLOW=20                                       # 数据库连接池最大溢出

# ---------- 服务器 ----------
HOST=0.0.0.0                                             # 监听地址
PORT=8000                                                # 监听端口
CLOUD_PORT=8000                                          # 云端端口
ADMIN_PORT=8012                                          # 管理端端口
ASSISTANT_PORT=8003                                      # 助手端端口
SALES_ASSISTANT_PORT=8004                                # 销售助手端端口
SALES_COACH_PORT=8001                                    # 销售教练端端口
PHARMA_INTEL_PORT=8006                                   # 制药情报端口
MARKET_ACCESS_PORT=8007                                  # 市场准入端口
CLINICAL_OPS_PORT=8010                                   # 临床运营端口
PATIENT_ENGAGE_PORT=8011                                 # 患者触达端口

# ---------- AI 路由 ----------
AI_ROUTING_ENABLED=false                                    # LLM 路由开关
AI_LOCAL_ENDPOINT=http://localhost:11434/api/generate       # 本地模型端点
AI_LOCAL_MODEL=deepseek-r1:7b                               # 本地模型名称
AI_CLOUD_AGENT_ENABLED=true                                 # Cloud Agent Mode 启用
AI_COMPLEXITY_THRESHOLD=2000                                # 复杂度阈值（字符数）

# ---------- 事件总线 ----------
REDIS_URL=redis://localhost:6379/0                              # Redis 连接地址（为空时使用 SQLite 后端）

# ---------- 兼容字段（旧版迁移） ----------
JWT_SECRET_KEY=your-production-key-here                       # 兼容旧版 JWT 密钥（与 SECRET_KEY 保持一致）
CORS_ORIGINS=*                                           # CORS 允许的域名
CLOUD_DB_PATH=data/cloud.db                             # 云服务数据库路径（兼容旧版）
ASSISTANT_DB_PATH=data/assistant.db                     # 助手端数据库路径（兼容旧版）
OPPORTUNITY_DB_PATH=data/opportunity.db                 # 机会端数据库路径（兼容旧版）
SALES_ASSISTANT_DB_PATH=data/sales_assistant.db         # 销售助手端数据库路径（兼容旧版）
SALES_COACH_DB_PATH=data/sales_coach.db                 # 销售教练端数据库路径（兼容旧版）

    }
  },
  {
    "code": "PHR-L1-014",
    "name": "竞品贬低禁止",
    "level": "L1",
    "action": "block",
    "severity": "high",
    "description": "学术推广中不得贬低或诋毁竞品",
    "detection": {
      "type": "keyword_match",
      "field": "notes",
      "keywords": ["劣于", "不如", "副作用大", "无效", "骗人"]
    }
  },
  {
    "code": "PHR-L1-015",
    "name": "临床试验数据合规",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "临床试验数据不得伪造、篡改或选择性报告",
    "detection": {
      "type": "field_check",
      "field": "trial_data_integrity",
      "operator": "eq",
      "value": false
    }
  },
  {

[
  {
    "code": "PHR-L1-001",
    "name": "备案身份核验",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "核验医药代表备案身份，未备案人员不得从事学术推广活动",
    "detection": {
      "type": "field_check",
      "field": "rep_verified",
      "operator": "eq",
      "value": false
    }
  },
  {
    "code": "PHR-L1-002",
    "name": "统方禁止",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "禁止以任何形式获取、使用医疗机构统方数据",
    "detection": {
      "type": "keyword_match",
      "field": "notes",
      "keywords": ["处方量", "开方数", "统方", "处方统计", "开药量"]
    }
  },
  {
    "code": "PHR-L1-003",
    "name": "利益输送拦截",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "拦截向医务人员提供财物或其他不正当利益的行为",
    "detection": {
      "type": "threshold",
      "field": "expenses",
      "operator": "gte",
      "value": 500,
      "exclude_when": {"field": "call_type", "operator": "eq", "value": "学术会议"}
    }
  },
  {
    "code": "PHR-L1-004",
    "name": "场所异常检测",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "检测并阻止在医疗机构内非指定区域进行的推广活动",
    "detection": {
      "type": "field_check",
      "field": "location_type",
      "operator": "eq",
      "value": "unauthorized"
    }
  },
  {
    "code": "PHR-L1-005",
    "name": "回扣红线",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "严禁以回扣、提成等方式诱导采购或处方行为",
    "detection": {
      "type": "keyword_match",
      "field": "notes",
      "keywords": ["回扣", "提成", "返点", "返利"]
    }
  },
  {
    "code": "PHR-L1-006",
    "name": "学术会议赞助合规",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "学术会议赞助须签订合规协议且金额不得超过规定上限",
    "detection": {
      "type": "threshold",
      "field": "sponsorship_amount",
      "operator": "gte",
      "value": 50000,
      "exclude_when": {"field": "sponsorship_approved", "operator": "eq", "value": true}
    }
  },
  {
    "code": "PHR-L1-007",
    "name": "讲课费标准",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "支付给医务人员的讲课费不得超过国家规定的单次标准",
    "detection": {
      "type": "threshold",
      "field": "lecture_fee",
      "operator": "gte",
      "value": 3000
    }
  },
  {
    "code": "PHR-L1-008",
    "name": "礼品限额",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "单次向HCP提供的礼品价值不得超过100元人民币",
    "detection": {
      "type": "threshold",
      "field": "gift_value",
      "operator": "gte",
      "value": 100
    }
  },
  {
    "code": "PHR-L1-009",
    "name": "用餐标准",
    "level": "L1",
    "action": "block",
    "severity": "high",
    "description": "商务用餐人均费用不得超过规定标准",
    "detection": {
      "type": "threshold",
      "field": "meal_per_person",
      "operator": "gte",
      "value": 300
    }
  },
  {
    "code": "PHR-L1-010",
    "name": "交通住宿标准",
    "level": "L1",
    "action": "block",
    "severity": "high",
    "description": "为HCP安排的交通住宿费用不得超过合规标准",
    "detection": {
      "type": "threshold",
      "field": "travel_accommodation_cost",
      "operator": "gte",
      "value": 2000
    }
  },
  {
    "code": "PHR-L1-011",
    "name": "HCP数据越权访问",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "未经授权访问HCP个人数据的行为",
    "detection": {
      "type": "field_check",
      "field": "data_access_authorized",
      "operator": "eq",
      "value": false
    }
  },
  {
    "code": "PHR-L1-012",
    "name": "患者隐私保护",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "禁止收集、使用或传播患者个人隐私信息",
    "detection": {
      "type": "keyword_match",
      "field": "notes",
      "keywords": ["患者姓名", "身份证号", "病历", "诊断信息", "床号"]
    }
  },
  {
    "code": "PHR-L1-013",
    "name": "适应症外推广禁止",
    "level": "L1",
    "action": "block",
    "severity": "critical",
    "description": "不得推广超出药品说明书适应症范围的使用",

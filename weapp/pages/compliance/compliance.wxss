.result {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 26rpx;
  margin-bottom: 18rpx;
}

.pass {
  color: #166534;
  background: #dcfce7;
}

.pending {
  color: #92400e;
  background: #fef3c7;
}

.check-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 76rpx;
  border-bottom: 1rpx solid #e2e8f0;
  font-size: 28rpx;
}

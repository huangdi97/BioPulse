<view class="page">
  <view wx:if="{{insights.length > 0}}" class="insight-card">
    <view class="insight-title">AI 洞察</view>
    <view class="insight-text">{{insights[0].summary}}</view>
  </view>
  <view class="title">HCP 查询</view>
  <view class="panel">
    <input class="field" placeholder="姓名 / 科室 / 医院" value="{{keyword}}" bindinput="onInput" confirm-type="search" bindconfirm="search" />
    <button class="button-primary" loading="{{loading}}" bindtap="search">搜索</button>
  </view>

  <block wx:if="{{hcps.length}}">
    <view class="panel" wx:for="{{hcps}}" wx:key="id" data-hcp="{{item}}" bindtap="selectHcp">
      <view class="hcp-name">{{item.name}}</view>
      <view class="muted">{{item.hospital || '未填写医院'}} · {{item.department || '未填写科室'}}</view>
      <view class="tag">等级 {{item.tier || 'C'}}</view>
    </view>
  </block>
  <view wx:else class="panel muted">暂无匹配 HCP</view>
</view>

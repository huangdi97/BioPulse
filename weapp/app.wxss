page {
  min-height: 100%;
  background: #f6f8fb;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  padding: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.muted {
  color: #64748b;
  font-size: 26rpx;
}

.field {
  min-height: 84rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  padding: 0 20rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
}

.button-primary {
  background: #0f766e;
  color: #ffffff;
  border-radius: 8rpx;
}

.button-secondary {
  background: #e0f2f1;
  color: #0f766e;
  border-radius: 8rpx;
}

.insight-card {
  margin: 10px;
  padding: 12px;
  border-left: 4px solid #3b82f6;
  background: #f0f9ff;
  border-radius: 8px;
  font-size: 14px;
}
.insight-card.green {
  border-color: #22c55e;
  background: #f0fdf4;
}
.insight-card.orange {
  border-color: #f97316;
  background: #fff7ed;
}
.insight-title {
  font-weight: bold;
  margin-bottom: 4px;
}
.insight-text {
  color: #666;
}

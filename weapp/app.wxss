page {
  min-height: 100%;
  background: #f6f8fb;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  padding: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.muted {
  color: #64748b;
  font-size: 26rpx;
}

.field {
  min-height: 84rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  padding: 0 20rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
}

.button-primary {
  background: #0f766e;
  color: #ffffff;
  border-radius: 8rpx;
}

.button-secondary {
  background: #e0f2f1;
  color: #0f766e;
  border-radius: 8rpx;
}

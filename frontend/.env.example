# ============================================================
# 一云四端 · 前端环境变量模板
# 复制本文件为 .env 后按需修改
# ============================================================

# ---------- API 网关 ----------
# 生产环境下 API 请求的目标地址
VITE_API_GATEWAY=http://localhost:8000

# ---------- 各后端服务端口（仅开发环境代理用） ----------
VITE_CLOUD_PORT=8000
VITE_COACH_PORT=8001
VITE_OPPORTUNITY_PORT=8002
VITE_ASSISTANT_PORT=8003
VITE_SALES_ASSISTANT_PORT=8004

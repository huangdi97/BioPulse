{
  "title": "Agent 执行延迟",
  "uid": "agent-overview",
  "panels": [
    {
      "title": "Agent 执行延迟分布 (P50/P95/P99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(agent_execution_duration_seconds_bucket[5m])) by (le, agent_key))", "legendFormat": "P50 {{agent_key}}"},
        {"expr": "histogram_quantile(0.95, sum(rate(agent_execution_duration_seconds_bucket[5m])) by (le, agent_key))", "legendFormat": "P95 {{agent_key}}"},
        {"expr": "histogram_quantile(0.99, sum(rate(agent_execution_duration_seconds_bucket[5m])) by (le, agent_key))", "legendFormat": "P99 {{agent_key}}"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"lineInterpolation": "smooth"}}
      }
    },
    {
      "title": "降级次数 (按 agent_key)",
      "type": "bargauge",
      "datasource": "Prometheus",
      "targets": [
        {"expr": "sum(increase(agent_degredation_total[24h])) by (agent_key)", "legendFormat": "{{agent_key}}"}
      ]
    }
  ]
}

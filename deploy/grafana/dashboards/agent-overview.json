{
  "title": "Agent Runtime Overview",
  "uid": "agent-overview",
  "version": 1,
  "panels": [
    {
      "title": "Agent Calls",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(agent_calls_total)",
          "legendFormat": "Total Calls"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 8}
    },
    {
      "title": "Call Success Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(agent_calls_total{status=~\"success|completed\"}) / sum(agent_calls_total) * 100",
          "legendFormat": "Success Rate"
        }
      ],
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 8}
    },
    {
      "title": "Call Duration (P50/P95)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_call_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_call_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    },
    {
      "title": "Calls by Agent",
      "type": "barchart",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(agent_calls_total) by (agent_key)",
          "legendFormat": "__auto"
        }
      ],
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8}
    },
    {
      "title": "Token Consumption by Model",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(agent_token_consumed_total[5m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8}
    },
    {
      "title": "Tool Calls by Agent",
      "type": "barchart",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(agent_tool_calls_total) by (agent_key)",
          "legendFormat": "__auto"
        }
      ],
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8}
    },
    {
      "title": "Calls by Status",
      "type": "piechart",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(agent_calls_total) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8}
    }
  ]
}

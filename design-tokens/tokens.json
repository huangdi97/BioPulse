{
  "version": "1.0",
  "name": "one4ends-design-system",
  "description": "BioPulse 统一设计系统 Token — Flutter + React 共用源文件",
  "colors": {
    "brand": {
      "primary": "#0f62fe",
      "primary_hover": "#0353e9",
      "primary_active": "#002d9c",
      "primary_light": "#edf5ff"
    },
    "mode": {
      "pharma": "#0f62fe",
      "research": "#8b5cf6",
      "compliance_warn": "#f59e0b",
      "compliance_pass": "#10b981"
    },
    "status": {
      "success": "#24a148",
      "error": "#da1e28",
      "warning": "#f1c21b",
      "info": "#0f62fe"
    },
    "neutral": {
      "white": "#ffffff",
      "gray_10": "#f4f4f4",
      "gray_20": "#e0e0e0",
      "gray_30": "#c6c6c6",
      "gray_50": "#8d8d8d",
      "gray_60": "#6f6f6f",
      "gray_70": "#525252",
      "gray_90": "#262626",
      "gray_100": "#161616"
    },
    "text": {
      "primary": "#161616",
      "secondary": "#525252",
      "placeholder": "#6f6f6f",
      "disabled": "#8d8d8d",
      "inverse": "#ffffff"
    },
    "surface": {
      "page": "#ffffff",
      "card": "#ffffff",
      "card_alt": "#f4f4f4",
      "hover": "#e8e8e8",
      "selected": "#edf5ff",
      "overlay": "rgba(22, 22, 22, 0.5)"
    },
    "border": {
      "default": "#e0e0e0",
      "subtle": "#c6c6c6",
      "input": "#f4f4f4",
      "focus": "#0f62fe",
      "error": "#da1e28"
    }
  },
  "typography": {
    "font_family": {
      "primary": "Inter",
      "mono": "JetBrains Mono"
    },
    "scale": {
      "display": { "size": 48, "weight": 600, "line_height": 1.1, "letter_spacing": -1.2 },
      "h1":       { "size": 32, "weight": 600, "line_height": 1.25, "letter_spacing": -0.6 },
      "h2":       { "size": 24, "weight": 600, "line_height": 1.33, "letter_spacing": -0.3 },
      "h3":       { "size": 20, "weight": 500, "line_height": 1.4, "letter_spacing": 0 },
      "body":     { "size": 16, "weight": 400, "line_height": 1.5, "letter_spacing": 0 },
      "body_sm":  { "size": 14, "weight": 400, "line_height": 1.4, "letter_spacing": 0.16 },
      "caption":  { "size": 12, "weight": 500, "line_height": 1.33, "letter_spacing": 0.32 },
      "label":    { "size": 12, "weight": 600, "line_height": 1.33, "letter_spacing": 0.32 },
      "mono":     { "size": 14, "weight": 400, "line_height": 1.4, "letter_spacing": 0 }
    }
  },
  "spacing": {
    "unit": 8,
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48,
    "xxxl": 64,
    "section": 80
  },
  "border_radius": {
    "none": 0,
    "sm": 4,
    "md": 6,
    "lg": 8,
    "xl": 12,
    "pill": 9999
  },
  "shadow": {
    "border": "0 0 0 1px rgba(0,0,0,0.08)",
    "card": "0 0 0 1px rgba(0,0,0,0.08), 0 2px 2px rgba(0,0,0,0.04)",
    "raised": "0 0 0 1px rgba(0,0,0,0.08), 0 4px 6px rgba(0,0,0,0.06)",
    "modal": "0 0 0 1px rgba(0,0,0,0.08), 0 8px 16px rgba(0,0,0,0.08)"
  }
}

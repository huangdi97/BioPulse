# ============================================================
# 一云四端 · 环境变量模板
# 复制为 .env 并按需修改
# ============================================================

# ---------- 通用 ----------
DEBUG=false                              # 调试模式
LOG_LEVEL=info                          # 日志级别: debug/info/warning/error
SECRET_KEY=change-me-to-a-random-string  # JWT 签名密钥（生产环境务必修改）
CORS_ORIGINS=*                          # 允许的跨域来源（逗号分隔或 *）

# ---------- 数据库 ----------
# 所有服务使用 SQLite，生产环境建议改为 PostgreSQL
CLOUD_DSN=sqlite:///data/cloud.db
SALES_COACH_DSN=sqlite:///data/sales_coach.db
OPPORTUNITY_DSN=sqlite:///data/opportunity.db
ASSISTANT_DSN=sqlite:///data/assistant.db
SALES_ASSISTANT_DSN=sqlite:///data/sales_assistant.db
PHARMA_INTEL_DSN=sqlite:///data/pharma_intel.db
MANAGEMENT_DSN=sqlite:///data/management.db

# ---------- 服务端口 ----------
CLOUD_PORT=8000
SALES_COACH_PORT=8001
OPPORTUNITY_PORT=8002
ASSISTANT_PORT=8003
SALES_ASSISTANT_PORT=8004
PHARMA_INTEL_PORT=8006
MANAGEMENT_PORT=8012

# ---------- 外部服务 ----------
# AI 网关配置（用于 Agent 调用）
AI_GATEWAY_URL=http://localhost:11434/v1
AI_GATEWAY_MODEL=deepseek-v4-pro
AI_GATEWAY_API_KEY=

# 短信服务（预留，当前未启用）
SMS_API_KEY=
SMS_API_SECRET=

# 邮件服务（预留，当前未启用）
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# BioPulse · Development Environment
# Copy to .env and adjust as needed

ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# CORS — allow all origins in development
CORS_ORIGINS=*

# Database
DATABASE_URL=sqlite:///./data/cloud.db

# Redis (optional in dev, leave empty for in-memory)
REDIS_URL=

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-dev-secret-key
SECRET_STORAGE_KEY=

# AI providers (optional in dev)
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Ports
CLOUD_PORT=8000
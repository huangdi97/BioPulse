# BioPulse · Production Environment
# Copy to .env and fill in all secrets

ENV=production
DEBUG=false
LOG_LEVEL=INFO

# CORS — MUST be explicitly set in production
CORS_ORIGINS=https://biopulse.com

# Database
DATABASE_URL=postgresql://user:password@host:5432/biopulse

# Redis — required in production for task queue and shared state
REDIS_URL=redis://:password@redis:6379/0

# JWT Secret (MUST be a strong random value)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-production-secret-key

# Secret storage key (MUST be set in production)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_STORAGE_KEY=

# AI providers
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Ports
CLOUD_PORT=8000